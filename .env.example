# ================================================================
# AI Provider API Keys
# ================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# You can also enter API keys directly in the app's sidebar
# ("AI 设置" → 勾选 "记住设置" 将持久化到本地配置文件).

OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
SILICONFLOW_API_KEY=

# ================================================================
# Custom API Configuration (optional)
# ================================================================
# For self-hosted or proxy endpoints (e.g., LiteLLM, vLLM, Ollama).
# These can also be configured in the app UI under "AI 设置".

CUSTOM_API_BASE_URL=
CUSTOM_MODEL_NAME=
CUSTOM_API_KEY=
