# ================================================================
# AI Provider API Keys
# ================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# You can also enter API keys directly in the app's AI Analysis tab
# ("记住设置" will persist them to your local user settings file).

OPENAI_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
SILICONFLOW_API_KEY=

# ================================================================
# Custom API Configuration (optional)
# ================================================================
# For self-hosted or proxy endpoints (e.g., LiteLLM, vLLM, Ollama).
# These can also be configured in the app UI under "自定义 API 配置".

CUSTOM_API_BASE_URL=
CUSTOM_MODEL_NAME=
CUSTOM_API_KEY=
